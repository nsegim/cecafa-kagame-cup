DATABASE_URI="postgresql://user:password@host/dbname?sslmode=require"
PAYLOAD_SECRET="YOUR_SECRET_HERE"

# IGIHE newsroom REST API
IGIHE_WP_BASE="https://old.igihe.com/wp-json/wp/v2"
