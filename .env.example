NEW_DB_DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
PAYLOAD_SECRET="YOUR_SECRET_HERE"

# --- Cloudinary (media uploads) ---------------------------------------------
# Media uploads are stored in Cloudinary. Create an account, then copy the three
# values from the Cloudinary dashboard. Without all three, Payload falls back to
# local disk storage (fine for local dev, not for production).
CLOUDINARY_CLOUD_NAME="YOUR_CLOUD_NAME"
CLOUDINARY_API_KEY="YOUR_API_KEY"
CLOUDINARY_API_SECRET="YOUR_API_SECRET"
# Optional: the folder every upload is stored under (default "cecafa").
# CLOUDINARY_FOLDER="cecafa"

# --- Optional seed admin credentials ----------------------------------------
# SEED_ADMIN_EMAIL="support@igihe.rw"
# SEED_ADMIN_PASSWORD="ChangeMe!"
